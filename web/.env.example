# Public frontend build-time configuration.
# Copy to web/.env for production builds.
# Used by canonical, Open Graph, robots.txt, sitemap.xml, AdSense script, and ads.txt.
VITE_SITE_URL=https://your-domain.xyz
VITE_SERVICE_OWNER=
VITE_CONTACT_EMAIL=hi@aigeniv.xyz
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_PUBLISHER_ID=
VITE_ADSENSE_HISTORY_SLOT=
# 本地预览广告位效果：设为 1 时展示模拟广告，不加载真实 AdSense
VITE_ADSENSE_MOCK=0
