# Agnes Image API 鉴权与服务配置
# 复制为 .env 并填入真实值

# Agnes API Key（单个，向后兼容；制定计划后由你提供）
AGNES_API_KEY=

# 多 API Key 共享池（负载均衡）：逗号分隔多个 key。
# 配置后系统会在多个 key 之间分配请求以分散压力；每个 key 各自独立 20 RPM，
# 总配额 = 单 key 配额 × key 数量。AGNES_API_KEYS 与 AGNES_API_KEY 会合并去重。
# 例：AGNES_API_KEYS=key_aaa,key_bbb,key_ccc
AGNES_API_KEYS=

# 本地无 Key 时的模拟模式（仅用于联调验证流程，返回占位图）。设为 1 开启
AGNES_MOCK=0
# 模拟模式下按概率注入 503 故障（0~1），用于验证重试/恢复，例如 0.5
AGNES_MOCK_FAIL_RATE=0

# Agnes 接口基础信息（一般无需修改）
AGNES_BASE_URL=https://apihub.agnes-ai.com
AGNES_ENDPOINT=/v1/images/generations
AGNES_MODEL=agnes-image-2.0-flash

# ===== 视频生成（Agnes Video V2.0）=====
# 创建视频任务接口
AGNES_VIDEO_ENDPOINT=/v1/videos
# 查询视频结果接口（推荐：GET /agnesapi?video_id=...）
AGNES_VIDEO_QUERY_ENDPOINT=/agnesapi
AGNES_VIDEO_MODEL=agnes-video-v2.0
# 视频创建请求超时（毫秒）
VIDEO_REQUEST_TIMEOUT_MS=300000
# 默认尺寸（文档默认 1152x768）
VIDEO_DEFAULT_WIDTH=1152
VIDEO_DEFAULT_HEIGHT=768
# 帧数：num_frames 必须 ≤ 441 且满足 8n+1（如 81/121/241/441）
VIDEO_MAX_FRAMES=441
VIDEO_DEFAULT_FRAMES=121
VIDEO_DEFAULT_FRAME_RATE=24
# 后端轮询上游查询结果的间隔（文档建议 5s）与总超时
VIDEO_POLL_INTERVAL_MS=5000
VIDEO_POLL_TIMEOUT_MS=600000

# ===== imgbb 图床（视频图生视频用）=====
# Agnes 视频接口仅支持图片 URL，本地上传的图片需先转存到 imgbb 换取公网 URL。
# 在 https://api.imgbb.com/ 申请 API Key 后填入。
IMGBB_API_KEY=
# imgbb 接口基础地址（一般无需修改）
IMGBB_BASE_URL=https://api.imgbb.com
# 上传请求超时（毫秒）
IMGBB_REQUEST_TIMEOUT_MS=60000
# 单图最大字节数（imgbb 上限 32MB = 33554432）
IMGBB_MAX_BYTES=33554432
# 图片自动过期时间（秒，60~15552000）；0 表示永不过期
IMGBB_EXPIRATION_SEC=0

# ===== RPM 限流（硬性要求：每个 Key 每分钟 20 次，图片/视频分别独立计算）=====
# 滑动窗口长度（毫秒），默认 1 分钟
RATE_LIMIT_WINDOW_MS=60000
# 单个 Key 图片生成每分钟最大请求数
IMAGE_RPM=20
# 单个 Key 视频生成每分钟最大请求数
VIDEO_RPM=20
# 配额耗尽时等待队列的轮询间隔（毫秒）
RATE_LIMIT_WAIT_POLL_MS=500
# 单个任务最长等待时间（毫秒），超时置失败
RATE_LIMIT_MAX_WAIT_MS=300000

# ===== 任务持久化（JSON 文件）=====
# 持久化文件路径（默认 server/data/tasks.json）
TASKS_DB_FILE=
# 任务保留时长（毫秒），默认 24 小时
TASKS_TTL_MS=86400000
# 最多保留任务条数
TASKS_MAX_ITEMS=500
# 写盘节流间隔（毫秒）
TASKS_FLUSH_INTERVAL_MS=800

# 后端服务端口
PORT=8787

# ===== 队列与限流（保守可配置）=====
# 最大并发请求数（默认 1：同一时间只处理一个任务，避免超出接口并发限制）
MAX_CONCURRENCY=1
# 两次请求之间的最小间隔（毫秒），用于平滑 RPM
MIN_INTERVAL_MS=500
# 单次请求超时（毫秒），文档建议 60s~360s
REQUEST_TIMEOUT_MS=300000
# 遇到 429/5xx 的最大重试次数
MAX_RETRIES=3
# 重试基础退避时间（毫秒），指数退避
RETRY_BASE_DELAY_MS=1500
# 单次重试退避上限（毫秒），避免指数退避无限增长
RETRY_MAX_DELAY_MS=20000
# 退避抖动比例（0~1），打散并发客户端的"同步重试"，缓解上游 503 二次冲击
RETRY_JITTER_RATIO=0.3

# ===== 大尺寸适配（控制请求尺寸，降低上游 GPU 资源占用，减少 503）=====
# 单张图像最大总像素（宽×高）。默认约 2.36MP（如 1920×1280），超出按比例缩小
IMAGE_MAX_PIXELS=2359296
# 单边最大长度
IMAGE_MAX_SIDE=2048
# 单边最小长度
IMAGE_MIN_SIDE=256
# 尺寸对齐步长（多数模型要求 8 的倍数）
IMAGE_SIZE_STEP=8
